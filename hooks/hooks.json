{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent|SendMessage",
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/ledger.py\"", "timeout": 10},
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/watchdog.py\"", "timeout": 10}
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/ledger.py\"", "timeout": 10}
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/ledger.py\"", "timeout": 10}
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/ledger.py\"", "timeout": 10},
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/watchdog.py\"", "timeout": 10}
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {"type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/watchdog.py\"", "timeout": 10}
        ]
      }
    ]
  }
}
