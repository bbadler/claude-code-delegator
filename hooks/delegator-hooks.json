{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent|SendMessage",
        "hooks": [{"type": "command", "command": "python3 __DELEGATOR_REPO__/hooks/ledger.py"}]
      }
    ],
    "SubagentStart": [
      {"hooks": [{"type": "command", "command": "python3 __DELEGATOR_REPO__/hooks/ledger.py"}]}
    ],
    "SubagentStop": [
      {"hooks": [{"type": "command", "command": "python3 __DELEGATOR_REPO__/hooks/ledger.py"}]}
    ],
    "TeammateIdle": [
      {"hooks": [{"type": "command", "command": "python3 __DELEGATOR_REPO__/hooks/ledger.py"}]}
    ]
  }
}
